<% content_for :title, "VPN9 — Privacy as Architecture. Zero Logs by Design." %>
<% content_for :meta_tags do %>
  <meta name="description" content="VPN9 is the only VPN whose architecture makes logging impossible. Anonymous accounts, crypto payments, fully open source. Verify it yourself — don't just trust us.">
  <meta name="keywords" content="VPN, privacy, no logs, anonymous VPN, Bitcoin VPN, Monero VPN, WireGuard, zero logs VPN, open source VPN, attestable VPN">
  <meta name="author" content="VPN9">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://vpn9.com/">

  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:title" content="VPN9 — Privacy as Architecture">
  <meta property="og:description" content="We don't know who you are. We can't. A VPN that makes surveillance technically impossible.">
  <meta property="og:image" content="<%= request.base_url %>/og-image.png">
  <meta property="og:site_name" content="VPN9">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= request.original_url %>">
  <meta name="twitter:title" content="VPN9 — Privacy as Architecture">
  <meta name="twitter:description" content="We don't know who you are. We can't.">
  <meta name="twitter:image" content="<%= request.base_url %>/twitter-card.png">
<% end %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
  <%= render_structured_data \
        structured_data_for_organization, \
        structured_data_for_website, \
        structured_data_for_vpn_service, \
        structured_data_for_faq, \
        graph: true %>
<% end %>

<style>
  :root {
    --ink: #0b0c0e;
    --ink-2: #111215;
    --ink-3: #16181c;
    --bone: #e8e6e1;
    --bone-dim: #a8a49c;
    --gray: #5a5a5a;
    --rule: rgba(232, 230, 225, 0.09);
    --rule-strong: rgba(232, 230, 225, 0.22);
    --amber: #f3c623;
    --amber-glow: rgba(243, 198, 35, 0.18);
    --blood: #ff4a2f;
    --mint: #8dffbc;
  }

  html, body { background: var(--ink); }

  .v9 {
    background: var(--ink);
    color: var(--bone);
    font-family: "Instrument Sans", ui-sans-serif, system-ui, sans-serif;
    font-feature-settings: "ss01", "ss02", "cv11";
    line-height: 1.5;
    overflow-x: hidden;
    min-height: 100vh;
    position: relative;
  }

  .v9 .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }
  .v9 .display {
    font-family: "Fraunces", "Times New Roman", serif;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 380;
    letter-spacing: -0.035em;
    line-height: 0.92;
  }
  .v9 .display em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 380;
    color: var(--amber);
    letter-spacing: -0.04em;
  }

  .v9 .label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bone-dim);
  }

  .v9 a { color: inherit; text-decoration: none; }
  .v9 ::selection { background: var(--amber); color: var(--ink); }

  /* --- noise overlay --- */
  .v9::before {
    content: "";
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    opacity: 0.035;
    mix-blend-mode: screen;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }

  /* --- ticker --- */
  .v9-ticker {
    border-bottom: 1px solid var(--rule);
    background: var(--ink);
    overflow: hidden;
    white-space: nowrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bone-dim);
    position: relative;
    z-index: 40;
  }
  .v9-ticker__track {
    display: inline-block;
    padding: 9px 0;
    animation: v9-ticker 50s linear infinite;
  }
  .v9-ticker span { margin: 0 2.2rem; }
  .v9-ticker .dot { color: var(--amber); margin: 0 1rem; }
  @keyframes v9-ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* --- nav --- */
  .v9-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 12, 14, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--rule);
  }
  .v9-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 440;
    font-size: 28px;
    letter-spacing: -0.02em;
    color: var(--bone);
  }
  .v9-logo__nine {
    color: var(--amber);
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 380, "SOFT" 100;
  }
  .v9-nav__links { display: none; gap: 2rem; }
  @media (min-width: 900px) { .v9-nav__links { display: inline-flex; } }
  .v9-nav__link {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bone-dim);
    transition: color 0.2s ease;
  }
  .v9-nav__link:hover { color: var(--bone); }
  .v9-nav__link::before { content: "·  "; color: var(--amber); }

  .v9-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* --- buttons --- */
  .v9-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    transition: transform 0.18s ease, background 0.2s ease, color 0.2s ease;
    border-radius: 0;
    cursor: pointer;
  }
  .v9-btn--primary {
    background: var(--amber);
    color: var(--ink);
    border: 1px solid var(--amber);
  }
  .v9-btn--primary:hover { background: #fdd94f; transform: translateY(-1px); }
  .v9-btn--ghost {
    background: transparent;
    color: var(--bone);
    border: 1px solid var(--rule-strong);
  }
  .v9-btn--ghost:hover { border-color: var(--bone); transform: translateY(-1px); }
  .v9-btn__arrow { transition: transform 0.2s ease; }
  .v9-btn:hover .v9-btn__arrow { transform: translateX(3px); }

  /* --- corner bracket panels --- */
  .v9-bracket {
    position: relative;
  }
  .v9-bracket::before, .v9-bracket::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: var(--amber);
    border-style: solid;
    border-width: 0;
  }
  .v9-bracket::before {
    top: -1px; left: -1px;
    border-top-width: 1px;
    border-left-width: 1px;
  }
  .v9-bracket::after {
    bottom: -1px; right: -1px;
    border-bottom-width: 1px;
    border-right-width: 1px;
  }
  .v9-bracket--all::before { /* still uses top-left */ }
  .v9-bracket--all {
    background-image:
      linear-gradient(to right, var(--amber), var(--amber)),
      linear-gradient(to bottom, var(--amber), var(--amber));
    background-position: top right, bottom left;
    background-size: 14px 1px, 1px 14px;
    background-repeat: no-repeat;
  }

  /* --- hero --- */
  .v9-hero {
    position: relative;
    padding: 80px 32px 100px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
  }
  @media (min-width: 1080px) {
    .v9-hero__grid { grid-template-columns: 1.55fr 1fr; align-items: end; gap: 48px; }
    .v9-hero { padding: 120px 40px 140px; }
  }
  .v9-hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 36px;
  }
  .v9-hero__kicker-dot {
    width: 7px;
    height: 7px;
    background: var(--mint);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(141, 255, 188, 0.6);
    animation: v9-pulse 1.8s ease-in-out infinite;
  }
  @keyframes v9-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .v9-hero__headline {
    font-size: clamp(54px, 10vw, 148px);
    margin: 0;
  }
  .v9-hero__headline .break { display: block; }
  .v9-hero__headline .underline-hand {
    position: relative;
    display: inline-block;
  }
  .v9-hero__headline .underline-hand::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.05em;
    height: 0.13em;
    background: var(--amber);
    opacity: 0.3;
    transform: skewX(-6deg);
  }

  .v9-hero__lede {
    margin-top: 38px;
    max-width: 48ch;
    color: var(--bone-dim);
    font-size: 17px;
    line-height: 1.55;
  }
  .v9-hero__lede strong { color: var(--bone); font-weight: 500; }

  .v9-hero__cta {
    margin-top: 42px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .v9-hero__meta {
    margin-top: 32px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--bone-dim);
  }
  .v9-hero__meta .amber { color: var(--amber); }

  /* status panel */
  .v9-status {
    padding: 28px 28px 24px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0) 80%);
    border: 1px solid var(--rule-strong);
    position: relative;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
  }
  .v9-status__head {
    display: flex;
    justify-content: space-between;
    padding-bottom: 18px;
    margin-bottom: 18px;
    border-bottom: 1px dashed var(--rule);
    color: var(--bone-dim);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .v9-status__blink {
    display: inline-block;
    width: 8px; height: 14px;
    background: var(--mint);
    vertical-align: -2px;
    margin-left: 2px;
    animation: v9-blink 1s steps(2) infinite;
  }
  @keyframes v9-blink { 50% { opacity: 0; } }
  .v9-status__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    padding: 7px 0;
    color: var(--bone);
  }
  .v9-status__row > span:first-child { color: var(--bone-dim); }
  .v9-status__row .dots { letter-spacing: 3px; color: var(--rule-strong); overflow: hidden; }
  .v9-status__row .val { font-weight: 500; }
  .v9-status__row .val.zero { color: var(--amber); }
  .v9-status__row .val.green { color: var(--mint); }

  /* --- section framing --- */
  .v9-sec {
    position: relative;
    padding: 100px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-sec__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }
  @media (min-width: 900px) {
    .v9-sec__head { grid-template-columns: 1fr 2fr; gap: 64px; }
  }
  .v9-sec__num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bone-dim);
    padding-top: 8px;
  }
  .v9-sec__num .amber { color: var(--amber); }
  .v9-sec__title {
    font-size: clamp(38px, 6vw, 82px);
    margin: 0;
  }

  /* --- manifesto (we don't know) --- */
  .v9-manifesto {
    display: grid;
    grid-template-columns: 1fr;
  }
  .v9-manifesto__row {
    display: grid;
    grid-template-columns: 46px 1fr auto;
    gap: 20px;
    padding: 26px 0;
    border-top: 1px solid var(--rule);
    align-items: baseline;
    position: relative;
  }
  .v9-manifesto__row:last-child { border-bottom: 1px solid var(--rule); }
  .v9-manifesto__row:hover .v9-manifesto__what { color: var(--amber); }
  .v9-manifesto__num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--bone-dim);
    letter-spacing: 0.14em;
  }
  .v9-manifesto__what {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 380;
    font-size: clamp(24px, 4vw, 42px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    transition: color 0.3s ease;
  }
  .v9-manifesto__what em {
    font-style: italic;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 380;
  }
  .v9-manifesto__marker {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0.7;
  }
  .v9-manifesto__coda {
    margin-top: 54px;
    max-width: 56ch;
    color: var(--bone-dim);
    font-size: 17px;
  }
  .v9-manifesto__coda strong { color: var(--bone); font-weight: 500; }

  /* --- architecture --- */
  .v9-arch {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    margin-top: 8px;
  }
  @media (min-width: 900px) {
    .v9-arch { grid-template-columns: repeat(3, 1fr); }
  }
  .v9-arch__card {
    padding: 32px 28px 36px;
    border: 1px solid var(--rule);
    background: var(--ink-2);
    position: relative;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .v9-arch__card:hover {
    border-color: var(--rule-strong);
    transform: translateY(-2px);
  }
  .v9-arch__step {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .v9-arch__title {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 400;
    font-size: 30px;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
    line-height: 1.08;
  }
  .v9-arch__body {
    color: var(--bone-dim);
    font-size: 15px;
    line-height: 1.55;
  }
  .v9-arch__diag {
    margin-top: auto;
    padding-top: 26px;
    border-top: 1px dashed var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    color: var(--bone-dim);
    letter-spacing: 0.02em;
    line-height: 1.7;
    white-space: pre;
    overflow: hidden;
  }
  .v9-arch__diag .k { color: var(--amber); }
  .v9-arch__diag .m { color: var(--mint); }
  .v9-arch__diag .x { color: var(--blood); }

  /* --- pricing --- */
  .v9-price {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--rule-strong);
    background: linear-gradient(180deg, rgba(255,255,255,0.015), transparent);
  }
  @media (min-width: 900px) {
    .v9-price { grid-template-columns: 1.4fr 1fr; }
  }
  .v9-price__body {
    padding: 56px 48px;
    border-bottom: 1px solid var(--rule);
  }
  @media (min-width: 900px) {
    .v9-price__body { border-bottom: 0; border-right: 1px solid var(--rule); }
  }
  .v9-price__tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 18px;
  }
  .v9-price__title {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 360;
    font-size: 44px;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
    line-height: 1;
  }
  .v9-price__lede {
    color: var(--bone-dim);
    font-size: 16px;
    max-width: 40ch;
    margin: 0 0 36px;
  }
  .v9-price__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--bone);
  }
  .v9-price__features li {
    list-style: none;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .v9-price__features svg { flex: none; color: var(--amber); margin-top: 2px; }

  .v9-price__side {
    padding: 56px 48px;
    background: radial-gradient(120% 80% at 50% 0%, rgba(243, 198, 35, 0.06), transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }
  .v9-price__number {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 320;
    font-size: clamp(100px, 14vw, 180px);
    line-height: 0.85;
    letter-spacing: -0.06em;
    color: var(--bone);
    display: flex;
    align-items: flex-start;
  }
  .v9-price__number .dollar {
    font-size: 0.32em;
    color: var(--amber);
    margin-right: 0.08em;
    margin-top: 0.2em;
    font-style: italic;
  }
  .v9-price__number .per {
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    letter-spacing: 0.15em;
    color: var(--bone-dim);
    align-self: flex-end;
    margin-bottom: 0.8em;
    margin-left: 0.6em;
    text-transform: uppercase;
  }
  .v9-pay {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .v9-pay__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-top: 1px dashed var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .v9-pay__row span:first-child { color: var(--bone-dim); }
  .v9-pay__row span:last-child { color: var(--bone); display: inline-flex; align-items: center; gap: 8px; }
  .v9-pay__coin {
    display: inline-block;
    width: 16px; height: 16px;
    border-radius: 50%;
  }
  .v9-pay__coin--btc { background: #f7931a; }
  .v9-pay__coin--xmr { background: #ff6600; }

  /* --- attestation --- */
  .v9-attest {
    border: 1px solid var(--rule);
    padding: 40px 40px 44px;
    background:
      repeating-linear-gradient(0deg, transparent 0 3px, rgba(243, 198, 35, 0.015) 3px 4px),
      var(--ink-2);
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    line-height: 1.75;
    position: relative;
    overflow: hidden;
  }
  .v9-attest__prompt {
    color: var(--amber);
    margin-right: 8px;
  }
  .v9-attest__line { color: var(--bone); display: block; }
  .v9-attest__line--dim { color: var(--bone-dim); }
  .v9-attest__line .key { color: var(--mint); }
  .v9-attest__line .str { color: #d8c4f7; }
  .v9-attest__line .num { color: var(--amber); }
  .v9-attest__cursor {
    display: inline-block;
    width: 9px;
    height: 17px;
    background: var(--amber);
    vertical-align: -3px;
    margin-left: 4px;
    animation: v9-blink 1s steps(2) infinite;
  }
  .v9-attest__watermark {
    position: absolute;
    right: 32px;
    bottom: 16px;
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 320;
    font-size: 100px;
    color: rgba(255,255,255,0.025);
    letter-spacing: -0.05em;
    pointer-events: none;
    line-height: 1;
  }

  /* --- CTA band --- */
  .v9-cta {
    margin: 80px 0 0;
    padding: 90px 40px 110px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
    position: relative;
    background:
      radial-gradient(60% 80% at 50% 100%, var(--amber-glow), transparent 60%);
  }
  .v9-cta__title {
    font-size: clamp(44px, 7vw, 96px);
    margin: 0 auto;
    max-width: 14ch;
  }
  .v9-cta__title em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 340;
    color: var(--amber);
  }
  .v9-cta__sub {
    margin-top: 26px;
    color: var(--bone-dim);
    font-size: 17px;
