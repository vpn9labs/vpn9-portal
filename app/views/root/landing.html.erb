      <%# --- Attestation --- %>
      <section id="verify" class="v9-sec" aria-label="Verify">
        <div class="v9-sec__head">
          <div class="v9-sec__num"><span class="amber">§04</span> &nbsp;/&nbsp; Attestation</div>
          <h2 class="v9-sec__title display">
            Don't take our word.<br><em>Take the proof.</em>
          </h2>
        </div>

        <div class="v9-attest">
          <span class="v9-attest__watermark">verify</span>
          <span class="v9-attest__line v9-attest__line--dim">// live attestation endpoint · GET /api/v1/attestation</span>
          <span class="v9-attest__line">
            <span class="v9-attest__prompt">$</span>curl <span class="str">https://vpn9.com/api/v1/attestation</span>
          </span>
          <br>
          <span class="v9-attest__line">{</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"build_version"</span>:&nbsp;<span class="str">"v1.4.2"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"build_commit"</span>:&nbsp;<span class="str">"955fbd3ab19c…"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"build_timestamp"</span>:&nbsp;<span class="str">"2025-10-14T03:18:44Z"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"image_digest"</span>:&nbsp;<span class="str">"sha256:d12e…f84c"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"sbom"</span>:&nbsp;<span class="str">"https://vpn9.com/sbom/v1.4.2.json"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"signature"</span>:&nbsp;<span class="str">"cosign://verifiable"</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"logs_retained"</span>:&nbsp;<span class="num">0</span>,</span>
          <span class="v9-attest__line">&nbsp;&nbsp;<span class="key">"data_retained"</span>:&nbsp;<span class="str">"none"</span></span>
          <span class="v9-attest__line">}<span class="v9-attest__cursor"></span></span>
          <br>
          <span class="v9-attest__line v9-attest__line--dim">// the running server identifies itself by digest.</span>
          <span class="v9-attest__line v9-attest__line--dim">// the digest matches a signed, reproducible build.</span>
          <span class="v9-attest__line v9-attest__line--dim">// the build matches source code you can read.</span>
          <span class="v9-attest__line v9-attest__line--dim">// if any link in that chain breaks, we lose your trust — and you notice.</span>
        </div>

        <div style="margin-top: 28px; display: grid; grid-template-columns: 1fr; gap: 16px;">
          <div style="display: grid; grid-template-columns: 1fr; gap: 16px;" class="v9-attest-links">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; border: 1px solid var(--rule); font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.06em;">
              <span><span style="color: var(--amber);">01 &nbsp;</span>Read the source</span>
              <a href="https://github.com/vpn9labs" target="_blank" rel="noopener" style="color: var(--amber); display: inline-flex; align-items: center; gap: 8px; text-transform: uppercase; letter-spacing: 0.18em; font-size: 11px;">
                github.com/vpn9labs
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 7L7 3M7 3H3.5M7 3V6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              </a>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; border: 1px solid var(--rule); font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.06em;">
              <span><span style="color: var(--amber);">02 &nbsp;</span>Check the running digest</span>
              <%= link_to transparency_path, style: "color: var(--amber); display: inline-flex; align-items: center; gap: 8px; text-transform: uppercase; letter-spacing: 0.18em; font-size: 11px;" do %>
                /transparency
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 7L7 3M7 3H3.5M7 3V6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              <% end %>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; border: 1px solid var(--rule); font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.06em;">
              <span><span style="color: var(--amber);">03 &nbsp;</span>Verify the signature</span>
              <%= link_to security_path, style: "color: var(--amber); display: inline-flex; align-items: center; gap: 8px; text-transform: uppercase; letter-spacing: 0.18em; font-size: 11px;" do %>
