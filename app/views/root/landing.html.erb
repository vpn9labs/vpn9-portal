<% end %>

<script>
  (function() {
    // Smooth-scroll for in-page anchor links
    document.querySelectorAll('.v9 a[href^="#"]').forEach(function(a) {
      a.addEventListener('click', function(e) {
        var id = a.getAttribute('href');
        if (id.length > 1) {
          var el = document.querySelector(id);
          if (el) {
            e.preventDefault();
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });

    // Subtle hover-glow on manifesto rows (staggered reveal via IntersectionObserver)
    var rows = document.querySelectorAll('.v9-manifesto__row');
    if ('IntersectionObserver' in window && rows.length) {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '0';
            entry.target.style.transform = 'translateY(8px)';
            entry.target.style.transition = 'opacity .6s ease, transform .6s ease';
            var idx = Array.prototype.indexOf.call(rows, entry.target);
            setTimeout(function() {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }, idx * 70);
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      rows.forEach(function(r) { io.observe(r); });
    }
  })();
</script>
