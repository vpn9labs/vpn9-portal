                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 7L7 3M7 3H3.5M7 3V6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <%# --- DNS leak test (shared partial, restyled via wrapper) --- %>
      <div class="v9-dns-shell" id="dns-test">
        <div class="v9-sec" style="padding-top: 64px; padding-bottom: 24px;">
          <div class="v9-sec__head">
            <div class="v9-sec__num"><span class="amber">※</span> &nbsp;/&nbsp; Diagnostic</div>
