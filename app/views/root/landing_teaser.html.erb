<%# VPN9 Teaser / Pre-Launch Landing Page %>
<% content_for :title, "VPN9 — Privacy as Architecture. Launching Soon." %>
<% content_for :meta_tags do %>
  <meta name="description" content="VPN9 is the only VPN whose architecture makes logging impossible. Anonymous accounts, crypto payments, fully open-source. Join the early-access list.">
  <meta name="keywords" content="VPN coming soon, privacy VPN launch, anonymous VPN, Bitcoin VPN, Monero VPN, zero logs VPN, open source VPN, attestable VPN">
  <meta name="author" content="VPN9">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://vpn9.com/">

  <%# Open Graph / Facebook %>
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:title" content="VPN9 — Launching Soon">
  <meta property="og:description" content="A VPN built so that it can't remember you. Be the first to know when we ship.">
  <meta property="og:site_name" content="VPN9">

  <%# Twitter %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= request.original_url %>">
  <meta name="twitter:title" content="VPN9 — Launching Soon">
  <meta name="twitter:description" content="When we launch, we won't know who you are. We can't.">
<% end %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
  <%= render_structured_data structured_data_for_organization %>
<% end %>

<style>
  :root {
    --ink: #0b0c0e;
    --ink-2: #111215;
    --ink-3: #16181c;
    --bone: #e8e6e1;
    --bone-dim: #a8a49c;
    --gray: #5a5a5a;
    --rule: rgba(232, 230, 225, 0.09);
    --rule-strong: rgba(232, 230, 225, 0.22);
    --amber: #f3c623;
    --amber-glow: rgba(243, 198, 35, 0.18);
    --blood: #ff4a2f;
    --mint: #8dffbc;
  }

  html, body { background: var(--ink); }

  .v9 {
    background: var(--ink);
    color: var(--bone);
    font-family: "Instrument Sans", ui-sans-serif, system-ui, sans-serif;
    font-feature-settings: "ss01", "ss02", "cv11";
    line-height: 1.5;
    overflow-x: hidden;
    min-height: 100vh;
    position: relative;
  }

  .v9 .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }
  .v9 .display {
    font-family: "Fraunces", "Times New Roman", serif;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 380;
    letter-spacing: -0.035em;
    line-height: 0.92;
  }
  .v9 .display em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 380;
    color: var(--amber);
    letter-spacing: -0.04em;
  }

  .v9 .label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bone-dim);
  }

  .v9 a { color: inherit; text-decoration: none; }
  .v9 ::selection { background: var(--amber); color: var(--ink); }

  /* --- noise overlay --- */
  .v9::before {
    content: "";
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    opacity: 0.035;
    mix-blend-mode: screen;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }

  /* --- ticker --- */
  .v9-ticker {
    border-bottom: 1px solid var(--rule);
    background: var(--ink);
    overflow: hidden;
    white-space: nowrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bone-dim);
    position: relative;
    z-index: 40;
  }
  .v9-ticker__track {
    display: inline-block;
    padding: 9px 0;
    animation: v9-ticker 50s linear infinite;
  }
  .v9-ticker span { margin: 0 2.2rem; }
  .v9-ticker .dot { color: var(--amber); margin: 0 1rem; }
  @keyframes v9-ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* --- nav --- */
  .v9-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 12, 14, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--rule);
  }
  .v9-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 440;
    font-size: 28px;
    letter-spacing: -0.02em;
    color: var(--bone);
  }
  .v9-logo__nine {
    color: var(--amber);
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 380, "SOFT" 100;
  }
  .v9-nav__links { display: none; gap: 2rem; }
  @media (min-width: 900px) { .v9-nav__links { display: inline-flex; } }
  .v9-nav__link {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bone-dim);
    transition: color 0.2s ease;
  }
  .v9-nav__link:hover { color: var(--bone); }
  .v9-nav__link::before { content: "·  "; color: var(--amber); }

  .v9-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* --- buttons --- */
  .v9-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    transition: transform 0.18s ease, background 0.2s ease, color 0.2s ease;
    border-radius: 0;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .v9-btn--primary {
    background: var(--amber);
    color: var(--ink);
    border-color: var(--amber);
  }
  .v9-btn--primary:hover { background: #fdd94f; transform: translateY(-1px); }
  .v9-btn--ghost {
    background: transparent;
    color: var(--bone);
    border-color: var(--rule-strong);
  }
  .v9-btn--ghost:hover { border-color: var(--bone); transform: translateY(-1px); }
  .v9-btn__arrow { transition: transform 0.2s ease; }
  .v9-btn:hover .v9-btn__arrow { transform: translateX(3px); }

  /* --- corner bracket panels --- */
  .v9-bracket { position: relative; }
  .v9-bracket::before, .v9-bracket::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: var(--amber);
    border-style: solid;
    border-width: 0;
  }
  .v9-bracket::before {
    top: -1px; left: -1px;
    border-top-width: 1px;
    border-left-width: 1px;
  }
  .v9-bracket::after {
    bottom: -1px; right: -1px;
    border-bottom-width: 1px;
    border-right-width: 1px;
  }

  /* --- hero --- */
  .v9-hero {
    position: relative;
    padding: 80px 32px 100px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
  }
  @media (min-width: 1080px) {
    .v9-hero__grid { grid-template-columns: 1.45fr 1fr; align-items: start; gap: 56px; }
    .v9-hero { padding: 120px 40px 140px; }
  }
  .v9-hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 36px;
  }
  .v9-hero__kicker-dot {
    width: 7px;
    height: 7px;
    background: var(--mint);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(141, 255, 188, 0.6);
    animation: v9-pulse 1.8s ease-in-out infinite;
  }
  @keyframes v9-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .v9-hero__headline {
    font-size: clamp(54px, 10vw, 148px);
    margin: 0;
  }
  .v9-hero__headline .break { display: block; }

  .v9-hero__lede {
    margin-top: 38px;
    max-width: 48ch;
    color: var(--bone-dim);
    font-size: 17px;
    line-height: 1.55;
  }
  .v9-hero__lede strong { color: var(--bone); font-weight: 500; }

  .v9-hero__cta {
    margin-top: 42px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .v9-hero__meta {
    margin-top: 32px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--bone-dim);
  }
  .v9-hero__meta .amber { color: var(--amber); }

  /* --- signup panel (hero right column) --- */
  .v9-signup {
    padding: 26px 26px 24px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0) 80%);
    border: 1px solid var(--rule-strong);
    position: relative;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
  }
  .v9-signup__head {
    display: flex;
    justify-content: space-between;
    padding-bottom: 18px;
    margin-bottom: 22px;
    border-bottom: 1px dashed var(--rule);
    color: var(--bone-dim);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .v9-signup__blink {
    display: inline-block;
    width: 8px; height: 14px;
    background: var(--mint);
    vertical-align: -2px;
    margin-left: 2px;
    animation: v9-blink 1s steps(2) infinite;
  }
  @keyframes v9-blink { 50% { opacity: 0; } }
  .v9-signup__title {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 360;
    font-size: clamp(40px, 5vw, 58px);
    line-height: 0.94;
    letter-spacing: -0.035em;
    color: var(--bone);
    margin: 0 0 14px;
  }
  .v9-signup__title em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 340;
    color: var(--amber);
  }
  .v9-signup__note {
    font-family: "Instrument Sans", sans-serif;
    font-size: 14px;
    color: var(--bone-dim);
    line-height: 1.55;
    margin: 0 0 26px;
  }
  .v9-signup__note strong { color: var(--bone); font-weight: 500; }
  .v9-signup__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v9-signup__label {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .v9-signup__input {
    width: 100%;
    padding: 14px 14px;
    background: var(--ink-3);
    border: 1px solid var(--rule-strong);
    color: var(--bone);
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    letter-spacing: 0.01em;
    border-radius: 0;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    box-sizing: border-box;
  }
  .v9-signup__input::placeholder { color: rgba(232, 230, 225, 0.28); }
  .v9-signup__input:focus {
    border-color: var(--amber);
    background: var(--ink-2);
  }
  .v9-signup__submit {
    margin-top: 8px;
    width: 100%;
    justify-content: center;
  }
  .v9-signup__msg {
    margin-top: 16px;
    padding: 12px 14px;
    border: 1px solid var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.02em;
    line-height: 1.5;
    color: var(--bone);
  }
  .v9-signup__msg strong { font-weight: 600; }
  .v9-signup__msg--ok {
    border-color: rgba(141,255,188,0.35);
    background: rgba(141,255,188,0.06);
    color: var(--mint);
  }
  .v9-signup__msg--err {
    border-color: rgba(255,74,47,0.35);
    background: rgba(255,74,47,0.06);
    color: var(--blood);
  }
  .v9-signup__foot {
    margin-top: 26px;
    padding-top: 18px;
    border-top: 1px dashed var(--rule);
  }
  .v9-signup__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    padding: 6px 0;
    color: var(--bone);
    font-family: "JetBrains Mono", monospace;
    font-size: 11.5px;
    align-items: baseline;
  }
  .v9-signup__row > span:first-child { color: var(--bone-dim); }
  .v9-signup__row .dots {
    letter-spacing: 3px;
    color: var(--rule-strong);
    overflow: hidden;
    white-space: nowrap;
  }
  .v9-signup__row .val { font-weight: 500; }
  .v9-signup__row .val.zero { color: var(--amber); }
  .v9-signup__row .val.amber { color: var(--amber); }
  .v9-signup__row .val.green { color: var(--mint); }
  .v9-signup__disclaim {
    margin-top: 18px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--bone-dim);
    line-height: 1.6;
    text-transform: uppercase;
  }
  .v9-signup__disclaim .amber { color: var(--amber); }
  .v9-signup__honeypot {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* --- section framing --- */
  .v9-sec {
    position: relative;
    padding: 100px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .v9-sec__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }
  @media (min-width: 900px) {
    .v9-sec__head { grid-template-columns: 1fr 2fr; gap: 64px; }
  }
  .v9-sec__num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bone-dim);
    padding-top: 8px;
  }
  .v9-sec__num .amber { color: var(--amber); }
  .v9-sec__title {
    font-size: clamp(38px, 6vw, 82px);
    margin: 0;
  }

  /* --- manifesto --- */
  .v9-manifesto {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0;
    margin: 0;
  }
  .v9-manifesto__row {
    display: grid;
    grid-template-columns: 46px 1fr auto;
    gap: 20px;
    padding: 26px 0;
    border-top: 1px solid var(--rule);
    align-items: baseline;
    position: relative;
    list-style: none;
  }
  .v9-manifesto__row:last-child { border-bottom: 1px solid var(--rule); }
  .v9-manifesto__row:hover .v9-manifesto__what { color: var(--amber); }
  .v9-manifesto__num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--bone-dim);
    letter-spacing: 0.14em;
  }
  .v9-manifesto__what {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 380;
    font-size: clamp(24px, 4vw, 42px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    transition: color 0.3s ease;
  }
  .v9-manifesto__what em {
    font-style: italic;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 380;
  }
  .v9-manifesto__marker {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0.7;
  }
  .v9-manifesto__coda {
    margin-top: 54px;
    max-width: 56ch;
    color: var(--bone-dim);
    font-size: 17px;
  }
  .v9-manifesto__coda strong { color: var(--bone); font-weight: 500; }

  /* --- architecture --- */
  .v9-arch {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    margin-top: 8px;
  }
  @media (min-width: 900px) {
    .v9-arch { grid-template-columns: repeat(3, 1fr); }
  }
  .v9-arch__card {
    padding: 32px 28px 36px;
    border: 1px solid var(--rule);
    background: var(--ink-2);
    position: relative;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .v9-arch__card:hover {
    border-color: var(--rule-strong);
    transform: translateY(-2px);
  }
  .v9-arch__step {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .v9-arch__title {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 400;
    font-size: 30px;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
    line-height: 1.08;
  }
  .v9-arch__body {
    color: var(--bone-dim);
    font-size: 15px;
    line-height: 1.55;
  }
  .v9-arch__diag {
    margin-top: auto;
    padding-top: 26px;
    border-top: 1px dashed var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    color: var(--bone-dim);
    letter-spacing: 0.02em;
    line-height: 1.7;
    white-space: pre;
    overflow: hidden;
  }
  .v9-arch__diag .k { color: var(--amber); }
  .v9-arch__diag .m { color: var(--mint); }
  .v9-arch__diag .x { color: var(--blood); }

  /* --- build progress matrix --- */
  .v9-progress {
    padding: 30px 32px 28px;
    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0) 80%);
    border: 1px solid var(--rule-strong);
    position: relative;
    font-family: "JetBrains Mono", monospace;
  }
  .v9-progress__head {
    display: flex;
    justify-content: space-between;
    padding-bottom: 18px;
    margin-bottom: 6px;
    border-bottom: 1px dashed var(--rule);
    color: var(--bone-dim);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: 10px;
  }
  .v9-progress__head .amber { color: var(--amber); }
  .v9-progress__row {
    display: grid;
    grid-template-columns: 34px 1.4fr 1.6fr auto;
    gap: 18px;
    padding: 13px 0;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
  }
  .v9-progress__row:last-of-type { border-bottom: 0; }
  .v9-progress__n {
    color: var(--bone-dim);
    letter-spacing: 0.12em;
    font-size: 11px;
  }
  .v9-progress__label {
    color: var(--bone);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: -0.005em;
    font-family: "Instrument Sans", sans-serif;
  }
  .v9-progress__detail {
    color: var(--bone-dim);
    font-size: 11.5px;
    letter-spacing: 0.02em;
  }
  .v9-progress__badge {
    font-size: 9.5px;
    letter-spacing: 0.2em;
    padding: 5px 11px;
    border: 1px solid currentColor;
    text-align: center;
    white-space: nowrap;
    font-weight: 500;
  }
  .v9-progress__badge--public { color: var(--mint); }
  .v9-progress__badge--ready  { color: var(--mint); }
  .v9-progress__badge--pilot  { color: var(--amber); background: rgba(243,198,35,0.05); }
  .v9-progress__badge--beta   { color: var(--amber); }
  .v9-progress__badge--wip    { color: var(--bone-dim); }
  .v9-progress__badge--upcoming { color: var(--bone-dim); opacity: 0.6; }
  .v9-progress__foot {
    margin-top: 22px;
    padding-top: 16px;
    border-top: 1px dashed var(--rule);
    color: var(--bone-dim);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    line-height: 1.6;
  }
  .v9-progress__foot a { color: var(--amber); border-bottom: 1px solid rgba(243,198,35,0.3); }
  .v9-progress__foot a:hover { border-bottom-color: var(--amber); }
  .v9-progress__foot code {
    color: var(--bone);
    background: var(--ink-3);
    padding: 2px 7px;
    font-size: 11px;
    letter-spacing: 0.02em;
  }
  @media (max-width: 760px) {
    .v9-progress__row {
      grid-template-columns: 28px 1fr auto;
      grid-template-areas:
        "n label  badge"
        ".  detail detail";
      gap: 6px 12px;
    }
    .v9-progress__n     { grid-area: n; }
    .v9-progress__label { grid-area: label; }
    .v9-progress__detail {
      grid-area: detail;
      padding-top: 4px;
      font-size: 11px;
    }
    .v9-progress__badge { grid-area: badge; }
  }

  /* --- attestation --- */
  .v9-attest {
    border: 1px solid var(--rule);
    padding: 40px 40px 44px;
    background:
      repeating-linear-gradient(0deg, transparent 0 3px, rgba(243, 198, 35, 0.015) 3px 4px),
      var(--ink-2);
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    line-height: 1.75;
    position: relative;
    overflow: hidden;
  }
  .v9-attest__prompt { color: var(--amber); margin-right: 8px; }
  .v9-attest__line { color: var(--bone); display: block; }
  .v9-attest__line--dim { color: var(--bone-dim); }
  .v9-attest__line .key { color: var(--mint); }
  .v9-attest__line .str { color: #d8c4f7; }
  .v9-attest__line .num { color: var(--amber); }
  .v9-attest__cursor {
    display: inline-block;
    width: 9px;
    height: 17px;
    background: var(--amber);
    vertical-align: -3px;
    margin-left: 4px;
    animation: v9-blink 1s steps(2) infinite;
  }
  .v9-attest__watermark {
    position: absolute;
    right: 32px;
    bottom: 16px;
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 320;
    font-size: 100px;
    color: rgba(255,255,255,0.025);
    letter-spacing: -0.05em;
    pointer-events: none;
    line-height: 1;
  }

  /* --- CTA band --- */
  .v9-cta {
    margin: 80px 0 0;
    padding: 90px 40px 110px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
    position: relative;
    background: radial-gradient(60% 80% at 50% 100%, var(--amber-glow), transparent 60%);
  }
  .v9-cta__title {
    font-size: clamp(44px, 7vw, 96px);
    margin: 0 auto;
    max-width: 16ch;
  }
  .v9-cta__title em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 340;
    color: var(--amber);
  }
  .v9-cta__sub {
    margin-top: 26px;
    color: var(--bone-dim);
    font-size: 17px;
    max-width: 52ch;
    margin-left: auto;
    margin-right: auto;
  }
  .v9-cta__buttons {
    margin-top: 42px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  /* --- footer --- */
  .v9-foot {
    padding: 64px 32px 48px;
    max-width: 1400px;
    margin: 0 auto;
    border-top: 1px solid var(--rule);
  }
  .v9-foot__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 32px;
  }
  @media (min-width: 900px) {
    .v9-foot__grid { grid-template-columns: 1.4fr repeat(4, 1fr); gap: 32px; }
  }
  .v9-foot__col h4 {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    margin: 0 0 20px;
    font-weight: 500;
  }
  .v9-foot__col a {
    display: block;
    font-size: 14px;
    color: var(--bone-dim);
    padding: 6px 0;
    transition: color 0.2s ease;
  }
  .v9-foot__col a:hover { color: var(--bone); }
  .v9-foot__tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--bone-dim);
    line-height: 1.7;
    margin-top: 14px;
    max-width: 38ch;
  }
  .v9-foot__key {
    margin-top: 20px;
    padding: 10px 12px;
    border: 1px dashed var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--bone-dim);
    letter-spacing: 0.08em;
    word-break: break-all;
    line-height: 1.55;
  }
  .v9-foot__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bone-dim);
    flex-wrap: wrap;
    gap: 16px;
  }
  .v9-foot__bottom .amber { color: var(--amber); margin-right: 8px; }

  /* --- DNS leak test override to match aesthetic --- */
  .v9-dns-shell {
    background: var(--ink);
    padding: 40px 0 20px;
    position: relative;
  }
  .v9-dns-shell > section { background: var(--ink) !important; padding: 20px 0 !important; }
  .v9-dns-shell h2 { color: var(--amber) !important; font-family: "JetBrains Mono", monospace; font-size: 11px !important; letter-spacing: 0.22em; text-transform: uppercase; }
  .v9-dns-shell > section > div > div > p {
    color: var(--bone) !important;
    font-family: "Fraunces", serif !important;
    font-variation-settings: "opsz" 72, "SOFT" 100, "wght" 380 !important;
    letter-spacing: -0.02em;
  }
  .v9-dns-shell > section > div > div > p + p {
    color: var(--bone-dim) !important;
    font-family: "Instrument Sans", sans-serif !important;
  }
  .v9-dns-shell .bg-white {
    background: var(--ink-2) !important;
    border: 1px solid var(--rule);
    box-shadow: none !important;
  }
  .v9-dns-shell .text-gray-900 { color: var(--bone) !important; }
  .v9-dns-shell .text-gray-600, .v9-dns-shell .text-gray-700 { color: var(--bone-dim) !important; }
  .v9-dns-shell .bg-black { background: var(--amber) !important; color: var(--ink) !important; }
  .v9-dns-shell .bg-black:hover { background: #fdd94f !important; }
  .v9-dns-shell .bg-blue-50 {
    background: transparent !important;
    border: 1px dashed var(--rule);
  }
  .v9-dns-shell .text-blue-900, .v9-dns-shell .text-blue-800 { color: var(--bone-dim) !important; }
  .v9-dns-shell button { border-radius: 0 !important; font-family: "JetBrains Mono", monospace !important; letter-spacing: 0.14em !important; text-transform: uppercase !important; font-size: 11px !important; }

  /* reveal on load — content stays visible by default; animation only runs when supported */
  @media (prefers-reduced-motion: no-preference) {
    .v9-reveal { animation: v9-in 0.9s cubic-bezier(.2,.7,.2,1) both; }
    @keyframes v9-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .v9-reveal[data-d="1"] { animation-delay: .05s; }
    .v9-reveal[data-d="2"] { animation-delay: .12s; }
    .v9-reveal[data-d="3"] { animation-delay: .2s; }
    .v9-reveal[data-d="4"] { animation-delay: .3s; }
    .v9-reveal[data-d="5"] { animation-delay: .4s; }
    .v9-reveal[data-d="6"] { animation-delay: .5s; }
  }

  /* grid background at hero */
  .v9-gridbg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(60% 60% at 50% 40%, black, transparent 80%);
    -webkit-mask-image: radial-gradient(60% 60% at 50% 40%, black, transparent 80%);
    opacity: 0.5;
  }

  /* hash marquee strip between sections */
  .v9-rule {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .v9-rule__inner {
    border-top: 1px solid var(--rule);
    padding: 16px 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.2em;
    color: var(--bone-dim);
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }
</style>

<div class="v9">
  <%# --- Ticker --- %>
  <div class="v9-ticker" aria-hidden="true">
    <div class="v9-ticker__track">
      <% marquee_items = [
        "EARLY ACCESS LIST · OPEN",
        "ZERO LOGS BY ARCHITECTURE",
        "NO EMAIL REQUIRED",
        "ANONYMOUS BY DESIGN",
        "BITCOIN · MONERO ACCEPTED",
        "WIREGUARD PROTOCOL",
        "OPEN SOURCE · AGPLv3",
        "REPRODUCIBLE BUILDS",
        "ATTESTABLE RUNTIME",
        "LAUNCH IMMINENT"
      ] %>
      <% 2.times do %>
        <% marquee_items.each do |item| %>
          <span><%= item %></span><span class="dot">◆</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# --- Navigation --- %>
  <header class="v9-nav">
    <div class="v9-nav__inner">
      <%= link_to root_path, class: "v9-logo" do %>
        VPN<span class="v9-logo__nine">9</span>
      <% end %>
      <nav class="v9-nav__links" aria-label="Primary">
        <a href="#manifesto" class="v9-nav__link">Principles</a>
        <a href="#architecture" class="v9-nav__link">Architecture</a>
        <a href="#progress" class="v9-nav__link">Progress</a>
        <a href="https://github.com/vpn9labs" target="_blank" rel="noopener" class="v9-nav__link">Source</a>
      </nav>
      <div class="v9-nav__cta">
        <a href="#signup-section" class="v9-btn v9-btn--primary">
          <span>Join the list</span>
          <svg class="v9-btn__arrow" width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
        </a>
      </div>
    </div>
  </header>

  <main role="main">
    <%# --- Hero --- %>
    <section class="v9-hero" aria-label="Coming Soon">
      <div class="v9-gridbg" aria-hidden="true"></div>
      <div class="v9-hero__grid">
        <div>
          <div class="v9-hero__kicker v9-reveal" data-d="1">
            <span class="v9-hero__kicker-dot"></span>
            <span class="label">VPN9 / PRIVACY AS ARCHITECTURE / LAUNCHING SOON</span>
          </div>
          <h1 class="v9-hero__headline display v9-reveal" data-d="2">
            <span class="break">When we launch,</span>
            <span class="break">we won't know</span>
            <span class="break"><em>who you are.</em></span>
          </h1>
          <p class="v9-hero__lede v9-reveal" data-d="3">
            VPN9 is the only VPN whose architecture makes surveillance
            <strong>technically impossible</strong>. No email. No metadata. No
            cross‑server correlation. Not because we delete the logs — because
            the system never produces them. Every line is open source. Every
            server will be attestable.
            <strong>Be the first to know when we ship.</strong>
          </p>
          <div class="v9-hero__cta v9-reveal" data-d="4">
            <a href="#signup-section" class="v9-btn v9-btn--primary">
              <span>Put me on the list</span>
              <svg class="v9-btn__arrow" width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
            </a>
            <a href="https://github.com/vpn9labs" target="_blank" rel="noopener" class="v9-btn v9-btn--ghost">
              <span>Read the source</span>
              <svg class="v9-btn__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
            </a>
          </div>
          <p class="v9-hero__meta v9-reveal" data-d="5">
            <span class="amber">※</span> No email required at launch <span class="amber">·</span> Pay with Bitcoin or Monero <span class="amber">·</span> AGPLv3
          </p>
        </div>

        <aside id="signup-section" class="v9-signup v9-bracket v9-reveal" data-d="6" aria-label="Waitlist signup">
          <div class="v9-signup__head">
            <span>EARLY ACCESS · REGISTRATION<span class="v9-signup__blink"></span></span>
            <span>◆ OPEN</span>
          </div>

          <h2 class="v9-signup__title">
            Be <em>first</em><br>in line.
          </h2>
          <p class="v9-signup__note">
            One email address. One message the day we ship. <strong>No drip
            campaign. No marketing. Unsubscribe in one click.</strong>
          </p>

          <%= form_with url: launch_notifications_path, local: false, html: { id: 'notification-form', class: 'v9-signup__form' } do |f| %>
            <%# Honeypot field — hidden from users, attracts bots %>
            <div class="v9-signup__honeypot" aria-hidden="true" tabindex="-1">
              <%= f.text_field :company, tabindex: "-1", autocomplete: "off" %>
            </div>

            <%# Hidden field for timing validation — server‑signed token %>
            <%= f.hidden_field :form_token, value: @form_timing_token %>

            <label class="v9-signup__label" for="notification_email">&gt;&nbsp; email_address</label>
            <%= f.email_field :email,
                  id: "notification_email",
                  placeholder: "you@your-own-domain.com",
                  required: true,
                  autocomplete: "email",
                  class: "v9-signup__input" %>

            <button type="submit" class="v9-btn v9-btn--primary v9-signup__submit">
              <span>Notify me at launch</span>
              <svg class="v9-btn__arrow" width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
            </button>
          <% end %>

          <%# Success %>
          <div id="success-message" class="v9-signup__msg v9-signup__msg--ok" style="display: none;">
            <strong>◆ On the list.</strong> One message will reach you the moment we open the door. Nothing else. Ever.
          </div>

          <%# Error %>
          <div id="error-message" class="v9-signup__msg v9-signup__msg--err" style="display: none;">
            <strong id="error-text">Something went wrong. Please try again.</strong>
          </div>

          <div class="v9-signup__foot">
            <div class="v9-signup__row">
              <span>Currently&nbsp;waiting</span>
              <span class="dots">· · · · · · · · · · · · · · · · · ·</span>
              <span class="val green" id="signup-count"><%= number_with_delimiter(@launch_notifications_count.to_i) %></span>
            </div>
            <div class="v9-signup__row">
              <span>Emails&nbsp;sold</span>
              <span class="dots">· · · · · · · · · · · · · · · · · ·</span>
              <span class="val zero">0</span>
            </div>
            <div class="v9-signup__row">
              <span>Subpoenas&nbsp;fulfilled</span>
              <span class="dots">· · · · · · · · · · · · · · · · · ·</span>
              <span class="val zero">0</span>
            </div>
            <div class="v9-signup__row">
              <span>Target&nbsp;launch</span>
              <span class="dots">· · · · · · · · · · · · · · · · · ·</span>
              <span class="val amber">SOON</span>
            </div>
          </div>

          <div class="v9-signup__disclaim">
            <span class="amber">※</span> Your address is hashed before storage and used solely to send the launch notice. Source code that handles it is public.
          </div>
        </aside>
      </div>
    </section>

    <%# --- Rule strip --- %>
    <div class="v9-rule">
      <div class="v9-rule__inner">
        <span>◐ §01 / 04 · The negative space</span>
        <span>Scroll to read</span>
      </div>
    </div>

    <%# --- Manifesto — 9 things we won't know --- %>
    <section id="manifesto" class="v9-sec" aria-label="What we won't know">
      <div class="v9-sec__head">
        <div class="v9-sec__num"><span class="amber">§01</span> &nbsp;/&nbsp; The nine unknowns</div>
        <h2 class="v9-sec__title display">
          Most VPNs say <em>trust us</em>.<br>
          We're building a system <em>that can't betray you</em>.
        </h2>
      </div>

      <ul class="v9-manifesto" role="list">
        <% manifesto_items = [
          ["Your IP address.", "NEVER STORED"],
          ["When you connect.", "NOT OBSERVED"],
          ["When you disconnect.", "NOT OBSERVED"],
          ["Which relay you choose.", "OUTSIDE OUR VIEW"],
          ["How much data you send.", "UNMEASURED"],
          ["What sites you visit.", "ENCRYPTED"],
          ["What apps you run.", "OPAQUE"],
          ["Who you are in real life.", "UNLINKABLE"],
          ["That any single account exists.", "UNCORRELATED"]
        ] %>
        <% manifesto_items.each_with_index do |(what, marker), i| %>
          <li class="v9-manifesto__row">
            <span class="v9-manifesto__num"><%= sprintf("%02d", i + 1) %></span>
            <span class="v9-manifesto__what">
              <% if i == 7 %>
                Who <em>you</em> are in real life.
              <% elsif i == 8 %>
                That any <em>single</em> account exists.
              <% else %>
                <%= what %>
              <% end %>
            </span>
            <span class="v9-manifesto__marker">— <%= marker %></span>
          </li>
        <% end %>
      </ul>

      <p class="v9-manifesto__coda">
        <strong>True privacy isn't about trusting us.</strong> It's about building
        a system where trust isn't required — and then publishing the blueprints
        so anyone can check the math.
      </p>
    </section>

    <%# --- Rule strip --- %>
    <div class="v9-rule">
      <div class="v9-rule__inner">
        <span>◐ §02 / 04 · How it's actually built</span>
        <span>↓</span>
      </div>
    </div>

    <%# --- Architecture --- %>
    <section id="architecture" class="v9-sec" aria-label="Architecture">
      <div class="v9-sec__head">
        <div class="v9-sec__num"><span class="amber">§02</span> &nbsp;/&nbsp; Architecture</div>
        <h2 class="v9-sec__title display">
          Privacy by <em>shape</em>,<br>not by policy.
        </h2>
      </div>

      <div class="v9-arch">
        <article class="v9-arch__card">
          <div class="v9-arch__step">STEP 01 · ACCOUNT</div>
          <h3 class="v9-arch__title">A 7‑word passphrase. Nothing else.</h3>
          <p class="v9-arch__body">
            No email, no phone, no identity document. Your passphrase is hashed
            with Argon2id and stored as bytes — never as anything we could link
            back to you. Add a password if you want. Or don't.
          </p>
<pre class="v9-arch__diag">
<span class="m">&gt;</span> signup()
  <span class="k">→</span> passphrase  = <span class="k">seven_words()</span>
  <span class="k">→</span> digest      = <span class="k">argon2id(</span>passphrase<span class="k">)</span>
  <span class="k">→</span> stored      = { digest, <span class="x">∅</span>, <span class="x">∅</span> }
  <span class="m">✓</span> no&nbsp;email.&nbsp;no&nbsp;phone.&nbsp;no&nbsp;name.</pre>
        </article>

        <article class="v9-arch__card">
          <div class="v9-arch__step">STEP 02 · TOKENS</div>
          <h3 class="v9-arch__title">A token that describes the right, not you.</h3>
          <p class="v9-arch__body">
            We issue a stateless JWT with a 24‑hour expiry. It carries the
            minimum a relay needs — and nothing more. Relays verify signatures
            locally. They don't call home. They don't tell us anything.
          </p>
<pre class="v9-arch__diag">
<span class="m">&gt;</span> jwt.claims
  <span class="k">sub</span>   : subscription_id
  <span class="k">exp</span>   : +24h
  <span class="k">iat</span>   : now()
  <span class="x">~</span> ip, name, email, device : <span class="x">absent</span>
  <span class="m">→</span> verified locally at relay</pre>
        </article>

        <article class="v9-arch__card">
          <div class="v9-arch__step">STEP 03 · RELAY</div>
          <h3 class="v9-arch__title">The relay forgets you the instant you leave.</h3>
          <p class="v9-arch__body">
            WireGuard in RAM only. No connection log, no bandwidth meter, no
            per‑session record. Disconnect and the tunnel is gone. The relay
            doesn't report session data anywhere — not even to us.
          </p>
<pre class="v9-arch__diag">
<span class="m">&gt;</span> wg up
  <span class="k">peer</span>  : client_pubkey
  <span class="k">ram</span>   : session_handle
  <span class="x">disk</span>  : <span class="x">—</span>
  <span class="x">api</span>   : <span class="x">no callbacks home</span>
  <span class="m">✓</span> forgotten on disconnect</pre>
        </article>
      </div>
    </section>

    <%# --- Rule strip --- %>
    <div class="v9-rule">
      <div class="v9-rule__inner">
        <span>◐ §03 / 04 · Build progress</span>
        <span>↓</span>
      </div>
    </div>

    <%# --- Build Progress Matrix --- %>
    <section id="progress" class="v9-sec" aria-label="Build Progress">
      <div class="v9-sec__head">
        <div class="v9-sec__num"><span class="amber">§03</span> &nbsp;/&nbsp; Progress</div>
        <h2 class="v9-sec__title display">
          Not a landing page <em>pretending</em><br>to be a company.
        </h2>
      </div>

      <div class="v9-progress v9-bracket">
        <div class="v9-progress__head">
          <span>BUILD MATRIX · <span class="amber">LIVE</span></span>
          <span>last refresh&nbsp;&nbsp;<%= Time.now.utc.strftime("%Y-%m-%d %H:%M") %>&nbsp;UTC</span>
        </div>

        <% progress_items = [
          { label: "Open-source code",         status: "public",   badge: "LIVE",     detail: "AGPLv3 · github.com/vpn9labs" },
          { label: "Anonymous accounts",       status: "ready",    badge: "READY",    detail: "7-word passphrase · Argon2id" },
          { label: "Bitcoin payments",         status: "ready",    badge: "READY",    detail: "via Bitcart · non-custodial" },
          { label: "Monero payments",          status: "ready",    badge: "READY",    detail: "via Bitcart · non-custodial" },
          { label: "WireGuard relay network",  status: "pilot",    badge: "PILOT",    detail: "RAM-only tunnels · no disk writes" },
          { label: "Runtime attestation",      status: "ready",    badge: "READY",    detail: "signed image digest · SBOM" },
          { label: "Desktop client",           status: "beta",     badge: "BETA",     detail: "macOS · Linux · Windows" },
          { label: "Mobile client",            status: "wip",      badge: "WIP",      detail: "iOS · Android" },
          { label: "Independent audit",        status: "upcoming", badge: "UPCOMING", detail: "scope signed with auditor" }
        ] %>
        <% progress_items.each_with_index do |item, i| %>
          <div class="v9-progress__row">
